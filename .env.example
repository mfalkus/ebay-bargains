# eBay API credentials for OAuth client-credentials flow.
# Get these from https://developer.ebay.com/my/keys (Production keys).
#
# IMPORTANT: Use the values from the *keys table* on that page:
#   - EBAY_CLIENT_ID  = "App ID (Client ID)"  (e.g. MyApp-PRD-abc123...)
#   - EBAY_CLIENT_SECRET = "Secret" (OAuth Client Secret)
#
# Do NOT paste the token from "Get OAuth Application Token" here.
# That button gives a temporary access token; this app needs the static App ID and Secret.
#
# UNLIMITED_IPS: comma-separated list of IPs that bypass rate limiting (e.g. your own IP or trusted clients).
# All other IPs are limited to 10 requests per minute and 100 per hour.

EBAY_CLIENT_ID=YourApp-PRD-xxxxxxxxxxxx
EBAY_CLIENT_SECRET=PRD-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
UNLIMITED_IPS=127.0.0.1,::1
